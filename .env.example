LLAMA_IMAGE=local/beellama-cuda-server:latest
BEELLAMA_REPO=https://github.com/Anbeeld/beellama.cpp.git

# Match this to the WSL distro version you run Docker integration against.
# You can detect this with: python3 scripts/detect_host_env.py
UBUNTU_VERSION=24.04

# Pick a CUDA image version supported by your installed NVIDIA driver.
# You can detect this with: python3 scripts/detect_host_env.py
CUDA_VERSION=13.3.0

# Optional: set to your GPU compute capability for a smaller/faster build,
# for example 86 for RTX 30xx, 89 for RTX 40xx, 120 for RTX 50xx.
# You can detect this with: python3 scripts/detect_host_env.py
CUDA_DOCKER_ARCH=default

# Shared memory available inside the container. Docker does not limit CPU/RAM
# unless you configure limits, so no CPU/memory limit is set in compose.
LLM_SHM_SIZE=16gb
