LLAMA_IMAGE=local/beellama-cuda-server:latest
BEELLAMA_REPO=https://github.com/Anbeeld/beellama.cpp.git

# Match this to the WSL distro version you run Docker integration against.
# You can detect this with: python3 scripts/detect_host_env.py
UBUNTU_VERSION=22.04

# Pick a CUDA image version supported by your installed NVIDIA driver.
# You can detect this with: python3 scripts/detect_host_env.py
CUDA_VERSION=12.4.1

# Optional: set to your GPU compute capability for a smaller/faster build,
# for example 86 for RTX 30xx, 89 for RTX 40xx, 120 for RTX 50xx.
# You can detect this with: python3 scripts/detect_host_env.py
CUDA_DOCKER_ARCH=default

# Shared memory available inside the container. Docker does not limit CPU/RAM
# unless you configure limits, so no CPU/memory limit is set in compose.
LLM_SHM_SIZE=16gb

# Model files are mounted from ./models to /models inside the container.
LLAMA_MODEL=Qwen3.6-27B-NEO-CODE-HERE-2T-OT-Q5_K_S.gguf
LLAMA_SPEC_DRAFT_MODEL=Qwen3.6-27B-DFlash-Q4_K_M.gguf

# llama-server runtime tuning.
LLAMA_SPEC_TYPE=dflash
LLAMA_SPEC_DFLASH_CROSS_CTX=1024
LLAMA_PARALLEL_SLOTS=1
LLAMA_N_GPU_LAYERS=all
LLAMA_SPEC_DRAFT_N_GPU_LAYERS=all
LLAMA_BATCH_SIZE=2048
LLAMA_UBATCH_SIZE=512
LLAMA_CONTEXT_SIZE=128000
LLAMA_CACHE_TYPE_K=q5_0
LLAMA_CACHE_TYPE_V=q4_1
LLAMA_FLASH_ATTN=on
LLAMA_REASONING=on
LLAMA_TEMP=0.6
LLAMA_TOP_K=20
LLAMA_TOP_P=1.0
LLAMA_MIN_P=0.0
